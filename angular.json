{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "k9n-dev": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "i18n": {
        "sourceLocale": "de",
        "locales": {
          "en": "src/locale/messages.en.xlf"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*.{jpg,jpeg,png,gif,svg,webp,avif}",
                "input": "src/content/blog",
                "output": "images/blog"
              },
              {
                "glob": "**/*.{jpg,jpeg,png,gif,svg,webp,avif}",
                "input": "src/content/talks",
                "output": "images/talks"
              },
              {
                "glob": "**/*.{jpg,jpeg,png,gif,svg,webp,avif}",
                "input": "src/content/projects",
                "output": "images/projects"
              }
            ],
            "styles": [
              "src/styles.css"
            ],
            "server": "src/main.server.ts",
            "outputMode": "static",
            "security": {
              "allowedHosts": []
            },
            "ssr": {
              "entry": "src/server.ts"
            },
            "i18nMissingTranslation": "warning"
          },
          "configurations": {
            "production": {
              "localize": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": ["de"]
            },
            "locale-en": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": ["en"]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "k9n-dev:build:production"
            },
            "development": {
              "buildTarget": "k9n-dev:build:development"
            },
            "development-en": {
              "buildTarget": "k9n-dev:build:development,locale-en"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "setupFiles": ["src/test-setup.ts"]
          }
        }
      }
    }
  }
}
